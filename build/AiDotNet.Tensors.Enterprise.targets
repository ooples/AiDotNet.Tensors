<Project>

  <!--
    AiDotNet.Tensors Enterprise build-flag gate (Phase 4).

    This file is auto-imported by the main csproj. It enforces that the
    DISABLE_TELEMETRY and DISABLE_LICENSE_GUARD compile-time constants
    can ONLY be set in builds that present a valid Ooples enterprise
    license. Without the license, the build fails before compilation
    reaches the #if-guarded code regions.

    Phase 4 — RSA-2048 PKCS#1 v1.5 SHA-256 signature verification via a
    precompiled MSBuild Task assembly shipped under build/LicenseValidator/.
    The task source (ValidateAiDotNetEnterpriseLicense.cs) and unit-test
    coverage (7 end-to-end tests) live in the same directory; see
    build/LicenseValidator/README.md for the keypair-generation procedure
    that produces the public key embedded in the task assembly.

    Rationale:
      - The OSS source is licensed under BSL 1.1 with commercial gates
        for non-trial production use. The BuildKey DRM and the telemetry
        subsystem implement parts of that commercial contract.
      - If an OSS consumer could simply pass -p:DefineConstants=DISABLE_LICENSE_GUARD
        to their `dotnet build`, they would bypass the commercial gates
        purely at compile time. That would render the BSL terms
        technically unenforceable in self-built deployments.
      - Locking the flags behind RSA-verified enterprise-license validation
        makes them genuine enterprise-tier benefits (custom builds for
        federal / air-gapped customers) instead of escape hatches.

    Validation flow:
      1. Build invocation defines DISABLE_TELEMETRY and/or DISABLE_LICENSE_GUARD.
      2. ValidateEnterpriseDisableFlags target inspects DefineConstants.
      3. If either flag is present, the target requires the
         AiDotNetEnterpriseLicenseKey MSBuild property AND
         AiDotNetEnterpriseLicensePath MSBuild property (or matching
         AIDOTNET_ENTERPRISE_LICENSE_KEY / _PATH env vars).
      4. The license file is loaded and passed to the
         ValidateAiDotNetEnterpriseLicense MSBuild Task (from
         build/LicenseValidator/bin/AiDotNet.Tensors.LicenseValidator.dll)
         which verifies:
           - marker == "AiDotNet-Enterprise-License-v1"
           - expires date is in the future (UTC)
           - every requested DISABLE_* flag is in the scope[] array
           - the base64-encoded payload's RSA-2048 PKCS#1 v1.5 SHA-256
             signature verifies against the validator's embedded public key
      5. Any failure produces a stable AIDOTNET* diagnostic and aborts
         the build before CoreCompile.

    Suppressing the gate is INTENTIONALLY HARD. There is no
    `AiDotNetSkipLicenseValidation` property. A determined adversary
    can fork the targets file out of their local checkout, but that
    constitutes a clear, demonstrable BSL violation — not a gray-area
    customer-friendly escape hatch.
  -->

  <PropertyGroup>
    <!--
      Exact ;-delimited token match, NOT a substring Contains. A bare
      DefineConstants.Contains('DISABLE_TELEMETRY') would also fire for an
      unrelated symbol that merely embeds the name (e.g. SOME_DISABLE_TELEMETRY_TEST),
      spuriously gating the build. Wrapping both the constants and the needle in
      ';' makes the match a whole-token comparison.
    -->
    <_AiDotNetDefineConstantsDelimited>;$(DefineConstants);</_AiDotNetDefineConstantsDelimited>
    <_AiDotNetDisableTelemetryRequested
      Condition="$(_AiDotNetDefineConstantsDelimited.Contains(';DISABLE_TELEMETRY;'))">true</_AiDotNetDisableTelemetryRequested>
    <_AiDotNetDisableLicenseGuardRequested
      Condition="$(_AiDotNetDefineConstantsDelimited.Contains(';DISABLE_LICENSE_GUARD;'))">true</_AiDotNetDisableLicenseGuardRequested>
    <_AiDotNetAnyDisableFlagRequested
      Condition="'$(_AiDotNetDisableTelemetryRequested)' == 'true' Or '$(_AiDotNetDisableLicenseGuardRequested)' == 'true'">true</_AiDotNetAnyDisableFlagRequested>

    <!--
      Resolved at MSBuild load time. The path is relative to THIS file
      (build/) so the lookup works the same whether the consumer is
      building from source or consuming a published NuGet that drops the
      validator DLL into the package's build/ directory.
    -->
    <_AiDotNetLicenseValidatorDll>$(MSBuildThisFileDirectory)LicenseValidator\bin\AiDotNet.Tensors.LicenseValidator.dll</_AiDotNetLicenseValidatorDll>
  </PropertyGroup>

  <!--
    Bootstrap-build the validator if the DLL isn't on disk yet. This
    runs ahead of every consuming target and is conditional so the
    overhead only fires when somebody actually requested a DISABLE_*
    flag (the only path that needs the validator). Source-builds where
    the validator project hasn't been built yet hit this; NuGet
    installs ship a pre-built copy and skip the bootstrap.
  -->
  <Target Name="EnsureAiDotNetLicenseValidatorBuilt"
          BeforeTargets="ValidateEnterpriseDisableFlags"
          Condition="'$(_AiDotNetAnyDisableFlagRequested)' == 'true' And !Exists('$(_AiDotNetLicenseValidatorDll)')">
    <Message Importance="high"
             Text="AiDotNet enterprise gate: building the license-validator task assembly because the precompiled DLL is missing at $(_AiDotNetLicenseValidatorDll)." />
    <!--
      RemoveProperties="TargetFramework": the parent build sets TargetFramework
      as a global property while multi-targeting (net10.0 / net471). Without
      stripping it, that value propagates into this inner build and the
      netstandard2.0 validator project is asked to build for net471 — which
      fails with MSB3644 (no net471 ref assemblies for a netstandard2.0
      project) and was the reason the net471 build path silently skipped the
      gate. Restore is included so the validator's BouncyCastle / System.Text.Json
      references resolve on a fresh source tree (otherwise NETSDK1004).
    -->
    <MSBuild Projects="$(MSBuildThisFileDirectory)LicenseValidator\AiDotNet.Tensors.LicenseValidator.csproj"
             Targets="Restore;Build"
             Properties="Configuration=Release"
             RemoveProperties="TargetFramework" />
  </Target>

  <!--
    No Condition="Exists(...)" here on purpose. UsingTask conditions are
    evaluated at project-evaluation time, before any target runs — so on a
    clean checkout where the validator DLL doesn't exist yet, a conditioned
    registration is silently skipped and stays skipped even after
    EnsureAiDotNetLicenseValidatorBuilt produces the DLL later in the same
    build, leaving ValidateEnterpriseDisableFlags unable to find the task.
    Registering unconditionally is safe: AssemblyFile is resolved lazily when
    the task is first invoked, which only happens inside
    ValidateEnterpriseDisableFlags (gated on a DISABLE_* flag) — and that
    target runs after the bootstrap has built the DLL. When no flag is
    requested the task is never invoked, so the path is never touched.
  -->
  <UsingTask
    TaskName="AiDotNet.Tensors.LicenseValidator.ValidateAiDotNetEnterpriseLicense"
    AssemblyFile="$(_AiDotNetLicenseValidatorDll)" />

  <Target Name="ValidateEnterpriseDisableFlags"
          BeforeTargets="CoreCompile"
          Condition="'$(_AiDotNetAnyDisableFlagRequested)' == 'true'">

    <PropertyGroup>
      <_AiDotNetEnterpriseLicenseKey
        Condition="'$(AiDotNetEnterpriseLicenseKey)' != ''">$(AiDotNetEnterpriseLicenseKey)</_AiDotNetEnterpriseLicenseKey>
      <_AiDotNetEnterpriseLicenseKey
        Condition="'$(_AiDotNetEnterpriseLicenseKey)' == ''">$([System.Environment]::GetEnvironmentVariable('AIDOTNET_ENTERPRISE_LICENSE_KEY'))</_AiDotNetEnterpriseLicenseKey>

      <_AiDotNetEnterpriseLicensePath
        Condition="'$(AiDotNetEnterpriseLicensePath)' != ''">$(AiDotNetEnterpriseLicensePath)</_AiDotNetEnterpriseLicensePath>
      <_AiDotNetEnterpriseLicensePath
        Condition="'$(_AiDotNetEnterpriseLicensePath)' == ''">$([System.Environment]::GetEnvironmentVariable('AIDOTNET_ENTERPRISE_LICENSE_PATH'))</_AiDotNetEnterpriseLicensePath>

      <_AiDotNetRequestedDisableFlags
        Condition="'$(_AiDotNetDisableTelemetryRequested)' == 'true'">DISABLE_TELEMETRY</_AiDotNetRequestedDisableFlags>
      <_AiDotNetRequestedDisableFlags
        Condition="'$(_AiDotNetDisableLicenseGuardRequested)' == 'true' And '$(_AiDotNetRequestedDisableFlags)' == ''">DISABLE_LICENSE_GUARD</_AiDotNetRequestedDisableFlags>
      <_AiDotNetRequestedDisableFlags
        Condition="'$(_AiDotNetDisableLicenseGuardRequested)' == 'true' And '$(_AiDotNetRequestedDisableFlags)' != '' And !$(_AiDotNetRequestedDisableFlags.Contains('DISABLE_LICENSE_GUARD'))">$(_AiDotNetRequestedDisableFlags);DISABLE_LICENSE_GUARD</_AiDotNetRequestedDisableFlags>
    </PropertyGroup>

    <Error
      Code="AIDOTNET001"
      Condition="'$(_AiDotNetEnterpriseLicenseKey)' == ''"
      Text="DISABLE_TELEMETRY / DISABLE_LICENSE_GUARD compile flags require a valid AiDotNet Enterprise license. AiDotNetEnterpriseLicenseKey MSBuild property (or AIDOTNET_ENTERPRISE_LICENSE_KEY env var) is not set. These build flags are Enterprise-tier benefits for air-gapped / federal customers — contact admin@aidotnet.dev to obtain an enterprise license. See https://aidotnet.dev/enterprise for details." />

    <Error
      Code="AIDOTNET002"
      Condition="'$(_AiDotNetEnterpriseLicensePath)' == ''"
      Text="DISABLE_TELEMETRY / DISABLE_LICENSE_GUARD compile flags require AiDotNetEnterpriseLicensePath (or AIDOTNET_ENTERPRISE_LICENSE_PATH env var) pointing to the signed license file issued by Ooples for your tenant. See https://aidotnet.dev/enterprise." />

    <Error
      Code="AIDOTNET003"
      Condition="'$(_AiDotNetEnterpriseLicensePath)' != '' And !Exists('$(_AiDotNetEnterpriseLicensePath)')"
      Text="AiDotNet Enterprise license file not found at: $(_AiDotNetEnterpriseLicensePath). Verify the path or contact admin@aidotnet.dev." />

    <Error
      Code="AIDOTNET010"
      Condition="!Exists('$(_AiDotNetLicenseValidatorDll)')"
      Text="AiDotNet Enterprise license validator DLL not found at: $(_AiDotNetLicenseValidatorDll). The EnsureAiDotNetLicenseValidatorBuilt bootstrap target should have built it; verify your build environment has the .NET SDK and can build netstandard2.0 projects. Contact admin@aidotnet.dev." />

    <ValidateAiDotNetEnterpriseLicense
      Condition="'$(_AiDotNetRequestedDisableFlags)' != '' And Exists('$(_AiDotNetLicenseValidatorDll)')"
      LicensePath="$(_AiDotNetEnterpriseLicensePath)"
      RequestedFlags="$(_AiDotNetRequestedDisableFlags)">
      <Output TaskParameter="Tenant" PropertyName="_AiDotNetEnterpriseLicenseTenant" />
    </ValidateAiDotNetEnterpriseLicense>

    <Message
      Importance="high"
      Condition="'$(_AiDotNetEnterpriseLicenseTenant)' != ''"
      Text="AiDotNet Enterprise build flags accepted (RSA-verified): tenant=$(_AiDotNetEnterpriseLicenseTenant), flags=$(_AiDotNetRequestedDisableFlags), license=$(_AiDotNetEnterpriseLicensePath)" />

  </Target>

  <!--
    Pack the enterprise gate into the .nupkg (CodeRabbit #439). This runs at
    pack time only (BeforeTargets="_GetPackageFiles", the NuGet pack
    file-collection target) so it never slows ordinary builds. It first builds
    the validator so its full output closure exists on disk, then adds the
    targets file + EVERY assembly in the validator's bin/ — picking up
    System.Text.Json's transitive netstandard2.0 closure (System.Text.Encodings.Web,
    Microsoft.Bcl.AsyncInterfaces, System.Memory, …) and BouncyCastle without
    hand-enumerating them. The items are added inside the target (not as static
    <None>) because the files don't exist until the validator is built, and a
    glob in a top-level ItemGroup is frozen at evaluation time before that build.
  -->
  <Target Name="PackLicenseValidatorAssets"
          BeforeTargets="_GetPackageFiles"
          Condition="'$(GeneratePackageOnBuild)' == 'true' Or '$(_IsPacking)' == 'true' Or '$(IsPackable)' != 'false'">
    <MSBuild Projects="$(MSBuildThisFileDirectory)LicenseValidator\AiDotNet.Tensors.LicenseValidator.csproj"
             Targets="Restore;Build"
             Properties="Configuration=Release"
             RemoveProperties="TargetFramework" />
    <ItemGroup>
      <!-- The NuGet-convention auto-import shim (build/<PackageId>.targets) plus
           the actual gate it forwards to. -->
      <None Include="$(MSBuildThisFileDirectory)AiDotNet.Tensors.targets">
        <Pack>true</Pack>
        <PackagePath>build\</PackagePath>
      </None>
      <None Include="$(MSBuildThisFileDirectory)AiDotNet.Tensors.Enterprise.targets">
        <Pack>true</Pack>
        <PackagePath>build\</PackagePath>
      </None>
      <None Include="$(MSBuildThisFileDirectory)LicenseValidator\bin\*.dll">
        <Pack>true</Pack>
        <PackagePath>build\LicenseValidator\bin\</PackagePath>
      </None>
    </ItemGroup>
  </Target>

</Project>
