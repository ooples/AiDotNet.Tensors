<Project>

  <!--
    NuGet auto-imports build/<PackageId>.targets (this file) into every project
    that consumes the AiDotNet.Tensors package. It forwards to the enterprise
    gate so a package consumer that compiles with DISABLE_TELEMETRY /
    DISABLE_LICENSE_GUARD still hits the RSA license check — the gate isn't only
    a source-tree concern. Builds from this repo's source import
    Enterprise.targets directly (see src/AiDotNet.Tensors/AiDotNet.Tensors.csproj),
    so this shim is exclusively the packaged-consumer entry point; the Exists
    guard keeps it inert if the gate file is somehow absent from the package.
  -->
  <Import Project="$(MSBuildThisFileDirectory)AiDotNet.Tensors.Enterprise.targets"
          Condition="Exists('$(MSBuildThisFileDirectory)AiDotNet.Tensors.Enterprise.targets')" />

</Project>
