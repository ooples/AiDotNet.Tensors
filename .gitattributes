# Normalize line endings: store text as LF in the repo, auto-detect binary.
* text=auto eol=lf

# Explicit source/text types -> LF in the working tree and repo.
*.cs        text eol=lf
*.csproj    text eol=lf
*.sln       text eol=lf
*.props     text eol=lf
*.targets   text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.xml       text eol=lf
*.txt       text eol=lf
*.sh        text eol=lf
*.editorconfig text eol=lf

# Windows-only scripts require CRLF.
*.cmd       text eol=crlf
*.bat       text eol=crlf
*.ps1       text eol=crlf

# Binary assets: never touch line endings.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.dll       binary
*.so        binary
*.dylib     binary
*.lib       binary
*.exe       binary
*.pdb       binary
*.zip       binary
*.gz        binary
*.onnx      binary
*.bin       binary
